# =====================================================================
# Lumora — environment variables (copy to .env for local development)
# packages/config parses & validates these at startup (fail-fast).
# =====================================================================

# ---- Runtime ----
NODE_ENV=development

# ---- App ----
# Public base URL of the web app
APP_URL=http://localhost:3000
# Base path for the REST API (SAD: /api/v1)
API_BASE_PATH=/api/v1

# ---- Database (local: docker-compose mongo) ----
MONGODB_URI=mongodb://localhost:27017/lumora

# ---- Redis (local: docker-compose redis) — cache, BullMQ queue, pub/sub ----
REDIS_URL=redis://localhost:6379

# ---- Auth (NextAuth.js + JWT access/refresh) ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-generated-secret
NEXTAUTH_URL=http://localhost:3000
# Access token lifetime (minutes) / refresh token lifetime (days)
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
# Google OAuth (FR-AUTH-07) — optional locally; leave blank to disable the provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Object storage (local: MinIO; cloud: AWS S3) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lumora-local
S3_ACCESS_KEY_ID=lumora
S3_SECRET_ACCESS_KEY=lumora-secret
# MinIO requires path-style addressing; AWS S3 does not
S3_FORCE_PATH_STYLE=true

# ---- Email (O-4: email only for now; local: Mailpit SMTP) ----
# Cloud will switch to Resend/SendGrid API. Locally we use SMTP against Mailpit.
EMAIL_TRANSPORT=smtp
EMAIL_FROM="Lumora <no-reply@lumora.local>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# When EMAIL_TRANSPORT=resend (cloud), set:
RESEND_API_KEY=

# ---- SMS ---- (O-4: DEFERRED — Twilio integration is out for now)

# ---- Uploads (NFR-SEC-05) — byte limits ----
MAX_VIDEO_UPLOAD_BYTES=2147483648
MAX_FILE_UPLOAD_BYTES=104857600

# ---- Observability (cloud phase) ----
SENTRY_DSN=

# ---- Live sessions (Phase 10 — O-5: build against provider APIs) ----
# Left blank until Phase 10; documented here so config is complete.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
MS_TEAMS_CLIENT_ID=
MS_TEAMS_CLIENT_SECRET=
MS_TEAMS_TENANT_ID=
